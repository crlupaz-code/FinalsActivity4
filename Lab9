<?php
$amount = readline("Enter purchase amount: ");

if ($amount >= 1000) {
    $discount = $amount * 0.20; // 20% discount
    $finalPrice = $amount - $discount;
    echo "20% discount applied. Final price: " . $finalPrice;
} elseif ($amount >= 500) {
    $discount = $amount * 0.10; // 10% discount
    $finalPrice = $amount - $discount;
    echo "10% discount applied. Final price: " . $finalPrice;
} else {
    echo "No discount applied. Final price: " . $amount;
}
?>
